#!/usr/bin/env bash

set -o errexit

DOTFILES_DIR="$HOME/Code/bjarnehelland/dotfiles"
LOG="/tmp/u-$(date +%Y-%m-%d-%H-%M-%S).txt"

gum style \
    --foreground 12 --border-foreground 12 --border double \
    --align center --width 60 --margin "1 0" --padding "1 0" \
    "$(printf '%s\n' \
    '‚Ėą‚Ėą‚ēó   ‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó  ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó' \
    '‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚Ėą‚Ėą‚ēó‚ēö‚ēź‚ēź‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚ēĚ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚ēź‚ēź‚ēĚ' \
    '‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĒ‚ēĚ‚Ėą‚Ėą‚ēĎ  ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó  ' \
    '‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚ēź‚ēĚ ‚Ėą‚Ėą‚ēĎ  ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚ēĚ  ' \
    '‚ēö‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĒ‚ēĚ‚Ėą‚Ėą‚ēĎ     ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĒ‚ēĚ‚Ėą‚Ėą‚ēĎ  ‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó' \
    ' ‚ēö‚ēź‚ēź‚ēź‚ēź‚ēź‚ēĚ ‚ēö‚ēź‚ēĚ     ‚ēö‚ēź‚ēź‚ēź‚ēź‚ēź‚ēĚ ‚ēö‚ēź‚ēĚ  ‚ēö‚ēź‚ēĚ   ‚ēö‚ēź‚ēĚ   ‚ēö‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēĚ')"

step() {
    local emoji="$1" title="$2"
    shift 2
    gum spin --spinner globe --title "$emoji $title" --show-output -- "$@" >> "$LOG" 2>&1
    echo "" >> "$LOG"
    echo "$emoji $title done"
}

step "ūüźô" "gh extensions upgrading..." gh extension upgrade --all
step "ūüí§" "lazy.nvim syncing..." nvim --headless "+Lazy! sync" +qa
step "ūüĆ≥" "nvim-treesitter updating..." nvim --headless "+TSUpdate" +qa

step "ūüćĽ" "brew updating..." brew update
step "ūüćĽ" "brew upgrading..." brew upgrade
step "ūüćĽ" "brew cleaning up..." brew cleanup --prune=all
step "ūüćĽ" "brew doctoring..." brew doctor || true
echo "ūüćĽ brew bundle (personal)..."
brew bundle --file="$DOTFILES_DIR/brew/Brewfile" | tee -a "$LOG"
if [ -f "$DOTFILES_DIR/brew/Brewfile.work" ]; then
    echo "ūüćĽ brew bundle (work)..."
    brew bundle --file="$DOTFILES_DIR/brew/Brewfile.work" | tee -a "$LOG"
fi

step "ūüćé" "mas upgrading..." mas upgrade

echo ""
echo "ūüßĺ logged to $LOG"
less "$LOG"
