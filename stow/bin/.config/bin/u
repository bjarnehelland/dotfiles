#!/usr/bin/env bash

DOTFILES_DIR="$HOME/Code/bjarnehelland/dotfiles"
LOG="/tmp/u-$(date +%Y-%m-%d-%H-%M-%S).txt"

gum style \
    --foreground 12 --border-foreground 12 --border double \
    --align center --width 60 --margin "1 0" --padding "1 0" \
    "$(printf '%s\n' \
    '██╗   ██╗██████╗ ██████╗  █████╗ ████████╗███████╗' \
    '██║   ██║██╔══██╗██╔══██╗██╔══██╗╚══██╔══╝██╔════╝' \
    '██║   ██║██████╔╝██║  ██║███████║   ██║   █████╗  ' \
    '██║   ██║██╔═══╝ ██║  ██║██╔══██║   ██║   ██╔══╝  ' \
    '╚██████╔╝██║     ██████╔╝██║  ██║   ██║   ███████╗' \
    ' ╚═════╝ ╚═╝     ╚═════╝ ╚═╝  ╚═╝   ╚═╝   ╚══════╝')"

ERRORS=()

step() {
    local emoji="$1" title="$2"
    shift 2
    gum spin --spinner globe --title "$emoji $title" -- "$@" >> "$LOG" 2>&1 || ERRORS+=("$title")
    echo "" >> "$LOG"
    if printf '%s\n' "${ERRORS[@]}" | grep -qF "$title"; then
        gum style --foreground 1 "  ✗ $title failed"
    else
        echo "  ✓ $title done"
    fi
}

bundle() {
    local label="$1" file="$2"
    echo "  … $label"
    local output
    output=$(brew bundle --file="$file" 2>&1) || true
    echo "$output" >> "$LOG"
    local installed upgraded failed
    installed=$(echo "$output" | grep -c "^Installing" || true)
    upgraded=$(echo "$output" | grep -c "^Upgrading" || true)
    failed=$(echo "$output" | grep -c "^Error:" || true)
    if [ "$failed" -gt 0 ]; then
        ERRORS+=("$label")
        echo "$output" | grep "^Installing\|^Upgrading\|^Error:" | sed 's/^/    /'
        gum style --foreground 1 "  ✗ $label: $failed error(s)"
    elif [ "$installed" -gt 0 ] || [ "$upgraded" -gt 0 ]; then
        echo "$output" | grep "^Installing\|^Upgrading" | sed 's/^/    /'
        echo "  ✓ $label: $installed installed, $upgraded upgraded"
    else
        echo "  ✓ $label: up to date"
    fi
}

echo ""
gum style --foreground 4 --bold "Tools"
step "🐙" "gh extensions" gh extension upgrade --all
step "💤" "lazy.nvim" nvim --headless "+Lazy! sync" +qa
step "🌳" "treesitter" nvim --headless "+TSUpdate" +qa

echo ""
gum style --foreground 4 --bold "Homebrew"
step "🍻" "brew update" brew update
step "🍻" "brew upgrade" brew upgrade
step "🍻" "brew autoremove" brew autoremove
step "🍻" "brew cleanup" brew cleanup --prune=all
step "🍻" "brew doctor" brew doctor

echo ""
gum style --foreground 4 --bold "Packages"
bundle "brewfile (personal)" "$DOTFILES_DIR/brew/Brewfile"
if [ -f "$DOTFILES_DIR/brew/Brewfile.work" ]; then
    bundle "brewfile (work)" "$DOTFILES_DIR/brew/Brewfile.work"
fi

# Remove packages not listed in any Brewfile
combined=$(mktemp)
cat "$DOTFILES_DIR/brew/Brewfile" > "$combined"
[ -f "$DOTFILES_DIR/brew/Brewfile.work" ] && cat "$DOTFILES_DIR/brew/Brewfile.work" >> "$combined"
orphans=$(brew bundle cleanup --file="$combined" 2>&1) || true
if [ -n "$orphans" ]; then
    echo "  Packages not in Brewfile:"
    echo "$orphans" | sed 's/^/    /'
    if gum confirm "  Uninstall orphaned packages?"; then
        brew bundle cleanup --force --file="$combined" >> "$LOG" 2>&1
        echo "  ✓ orphans removed"
    else
        echo "  … skipped"
    fi
else
    echo "  ✓ no orphaned packages"
fi
rm -f "$combined"

echo ""
gum style --foreground 4 --bold "App Store"
step "🍎" "mas upgrade" mas upgrade

echo ""
if [ ${#ERRORS[@]} -gt 0 ]; then
    gum style --foreground 1 --bold "⚠ ${#ERRORS[@]} error(s):"
    for err in "${ERRORS[@]}"; do
        gum style --foreground 1 "  • $err"
    done
else
    gum style --foreground 2 --bold "All up to date ✓"
fi

echo ""
echo "Log: $LOG"
