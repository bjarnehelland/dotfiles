#!/usr/bin/env bash

DOTFILES_DIR="$HOME/Code/bjarnehelland/dotfiles"
LOG="/tmp/u-$(date +%Y-%m-%d-%H-%M-%S).txt"

gum style \
    --foreground 12 --border-foreground 12 --border double \
    --align center --width 60 --margin "1 0" --padding "1 0" \
    "$(printf '%s\n' \
    '‚Ėą‚Ėą‚ēó   ‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó  ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó' \
    '‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚Ėą‚Ėą‚ēó‚ēö‚ēź‚ēź‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚ēĚ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚ēź‚ēź‚ēĚ' \
    '‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĒ‚ēĚ‚Ėą‚Ėą‚ēĎ  ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó  ' \
    '‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚ēź‚ēĚ ‚Ėą‚Ėą‚ēĎ  ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚ēĚ  ' \
    '‚ēö‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĒ‚ēĚ‚Ėą‚Ėą‚ēĎ     ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĒ‚ēĚ‚Ėą‚Ėą‚ēĎ  ‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó' \
    ' ‚ēö‚ēź‚ēź‚ēź‚ēź‚ēź‚ēĚ ‚ēö‚ēź‚ēĚ     ‚ēö‚ēź‚ēź‚ēź‚ēź‚ēź‚ēĚ ‚ēö‚ēź‚ēĚ  ‚ēö‚ēź‚ēĚ   ‚ēö‚ēź‚ēĚ   ‚ēö‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēĚ')"

ERRORS=()

step() {
    local emoji="$1" title="$2"
    shift 2
    gum spin --spinner globe --title "$emoji $title" -- "$@" >> "$LOG" 2>&1 || ERRORS+=("$title")
    echo "" >> "$LOG"
    if printf '%s\n' "${ERRORS[@]}" | grep -qF "$title"; then
        gum style --foreground 1 "  ‚úó $title failed"
    else
        echo "  ‚úď $title done"
    fi
}

bundle() {
    local label="$1" file="$2"
    echo "  ‚Ä¶ $label"
    local output
    output=$(brew bundle --file="$file" 2>&1) || true
    echo "$output" >> "$LOG"
    local installed upgraded failed
    installed=$(echo "$output" | grep -c "^Installing" || true)
    upgraded=$(echo "$output" | grep -c "^Upgrading" || true)
    failed=$(echo "$output" | grep -c "^Error:" || true)
    if [ "$failed" -gt 0 ]; then
        ERRORS+=("$label")
        echo "$output" | grep "^Installing\|^Upgrading\|^Error:" | sed 's/^/    /'
        gum style --foreground 1 "  ‚úó $label: $failed error(s)"
    elif [ "$installed" -gt 0 ] || [ "$upgraded" -gt 0 ]; then
        echo "$output" | grep "^Installing\|^Upgrading" | sed 's/^/    /'
        echo "  ‚úď $label: $installed installed, $upgraded upgraded"
    else
        echo "  ‚úď $label: up to date"
    fi
}

echo ""
gum style --foreground 4 --bold "Tools"
step "ūüźô" "gh extensions" gh extension upgrade --all
step "ūüí§" "lazy.nvim" nvim --headless "+Lazy! sync" +qa
step "ūüĆ≥" "treesitter" nvim --headless "+TSUpdate" +qa

echo ""
gum style --foreground 4 --bold "Homebrew"
step "ūüćĽ" "brew update" brew update
step "ūüćĽ" "brew upgrade" brew upgrade
step "ūüćĽ" "brew cleanup" brew cleanup --prune=all
step "ūüćĽ" "brew doctor" brew doctor

echo ""
gum style --foreground 4 --bold "Packages"
bundle "brewfile (personal)" "$DOTFILES_DIR/brew/Brewfile"
if [ -f "$DOTFILES_DIR/brew/Brewfile.work" ]; then
    bundle "brewfile (work)" "$DOTFILES_DIR/brew/Brewfile.work"
fi

echo ""
gum style --foreground 4 --bold "App Store"
step "ūüćé" "mas upgrade" mas upgrade

echo ""
if [ ${#ERRORS[@]} -gt 0 ]; then
    gum style --foreground 1 --bold "‚ö† ${#ERRORS[@]} error(s):"
    for err in "${ERRORS[@]}"; do
        gum style --foreground 1 "  ‚ÄĘ $err"
    done
else
    gum style --foreground 2 --bold "All up to date ‚úď"
fi

echo ""
echo "Log: $LOG"
